--[[ 
    SCRIPT LẤY KEY - CHỈ GỬI IPA KHI BẤM NÚT "GET KEY"
]]

local Web_URL = "https://depzaihub.vercel.app"  -- Thay bằng URL web của bạn
local KeyCacheFile = "DeviceKeyCache.txt"

-- === TẠO IPA DUY NHẤT (ẨN) ===
local function generateIPA()
    local player = game:GetService("Players").LocalPlayer
    local userId = player.UserId
    local gameId = game.GameId
    local random = math.random(10000, 99999)
    local ipa = string.sub(tostring(userId) .. tostring(gameId) .. tostring(random), 1, 12)
    return ipa:upper()
end

-- === LẤY IPA ĐÃ LƯU ===
local function getDeviceIPA()
    if readfile and isfile and isfile(KeyCacheFile) then
        local saved = readfile(KeyCacheFile)
        if saved and #saved >= 6 then
            return saved
        end
    end
    local newIPA = generateIPA()
    if writefile then
        pcall(function() writefile(KeyCacheFile, newIPA) end)
    end
    return newIPA
end

-- === GỬI IPA LÊN WEB VÀ LẤY KEY (CHỈ GỌI KHI BẤM NÚT) ===
local function fetchKeyFromWeb(ipa)
    local fullURL = Web_URL .. "?action=getkey&ipa=" .. ipa
    print("[KEY] Đang gửi yêu cầu lấy key...")
    
    local success, response = pcall(function()
        return game:HttpGet(fullURL)
    end)
    
    if success and response then
        -- Web trả về key dạng HOANG_XXXXXXXX
        local key = string.match(response, "HOANG_[A-Z0-9]+")
        if key then
            print("[KEY] ✅ Key cho thiết bị: " .. key)
            return key
        else
            -- Thử tìm trong HTML nếu web trả về trang
            key = string.match(response, "HOANG_[A-Z0-9]+")
            if key then
                print("[KEY] ✅ Key từ HTML: " .. key)
                return key
            end
        end
    else
        print("[KEY] ❌ Không thể lấy key: " .. tostring(response))
    end
    return nil
end

-- === LƯU KEY ===
local function saveKey(key)
    if writefile then
        pcall(function() writefile(KeyCacheFile .. "_key", key) end)
    end
end

